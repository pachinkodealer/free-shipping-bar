# Shopify app credentials — get from Partner Dashboard > Apps > API credentials
SHOPIFY_API_KEY="your-api-key"
SHOPIFY_API_SECRET="your-api-secret"

# The public URL where this app is hosted (Railway URL in production)
SHOPIFY_APP_URL="https://your-app.up.railway.app"

# OAuth scopes
SCOPES="read_products"

# Database
# Local dev:    DATABASE_URL="file:./dev.sqlite"
# Production:   DATABASE_URL="postgresql://..." (from Railway PostgreSQL)
DATABASE_URL="file:./dev.sqlite"
